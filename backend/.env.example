# ===== 돌봄ON backend 환경변수 =====
# 이 파일은 .gitignore에 등록되어 커밋되지 않습니다. 아래 두 값을 채워주세요.

# Claude API 키 (https://platform.claude.com 에서 발급)
ANTHROPIC_API_KEY=

# Firebase 서비스 계정 키 JSON 파일의 절대경로
# (Firebase 콘솔 > 프로젝트 설정 > 서비스 계정 > "새 비공개 키 생성"으로 다운로드)
# 예: D:/0_cwnu/0_Activity/2026_Tech4Goods/Tech4Good/backend/firebase-service-account.json
FIREBASE_CREDENTIALS_PATH=
